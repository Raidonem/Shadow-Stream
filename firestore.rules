
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHADOWSTREAM SECURITY RULES - SYNCED FOR PROJECT: shadows-16567
     * Enhanced privacy controls for user profiles and friend system.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    function isFriend(userId) {
      let friendshipId = request.auth.uid < userId 
        ? request.auth.uid + "_" + userId 
        : userId + "_" + request.auth.uid;
      return isSignedIn() && exists(/databases/$(database)/documents/friendships/$(friendshipId));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow reading profile if owner OR if profile is marked public OR if users are friends
      allow get: if isOwner(userId) || resource.data.isPublic == true || isFriend(userId);
      // Allow searching for public users
      allow list: if isSignedIn() && (request.query.limit <= 20 || isAdmin()); 
      
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /history/{historyId} {
        // Watching history is ALWAYS strictly private
        allow read, write: if isOwner(userId);
      }
    }

    match /friendships/{friendshipId} {
      // friendships ID format is minUid_maxUid
      allow read: if isSignedIn() && request.auth.uid in resource.data.userIds;
      // Friendships should ideally only be created by server logic or validated carefully
      // For now, allow create if the user is one of the parties
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.userIds && 
                    friendshipId == (request.resource.data.userIds[0] < request.resource.data.userIds[1] 
                      ? request.resource.data.userIds[0] + "_" + request.resource.data.userIds[1]
                      : request.resource.data.userIds[1] + "_" + request.resource.data.userIds[0]);
      allow delete: if isSignedIn() && request.auth.uid in resource.data.userIds;
    }

    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId && request.auth.uid != request.resource.data.receiverId;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.receiverId);
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if (
        isAdmin() || 
        (
          isSignedIn() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'updatedAt', 'views'])
        )
      ) && resource != null;
      allow delete: if isAdmin() && resource != null;

      match /episodes/{episodeId} {
        allow get, list: if true;
        allow create: if isAdmin() && request.resource.data.animeId == animeId;
        allow update, delete: if isAdmin() && resource != null;

        match /comments/{commentId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.episodeId == episodeId && request.resource.data.text.size() <= 100;
          allow update: if (isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId && request.resource.data.text.size() <= 100) || 
                         (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes', 'updatedAt', 'userName', 'userDisplayName']));
          allow delete: if isExistingOwner(resource.data.userId) || isAdmin();
        }
      }
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    match /ratings/{ratingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    match /comment_votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && voteId == request.auth.uid + "_" + request.resource.data.commentId;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    // Support for Collection Group queries on 'comments'
    match /{path=**}/comments/{commentId} {
      allow list: if isSignedIn();
      allow read: if true;
      allow update: if (isSignedIn() && request.auth.uid == resource.data.userId) || 
                       (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes', 'updatedAt', 'userName', 'userDisplayName']));
    }

    match /global_notifications/{notificationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
