
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuspended() {
      let profile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && profile.data.suspensionUntil != null && duration.value(request.time - timestamp.value(profile.data.suspensionUntil)) < 0;
    }

    function isCommentRestricted() {
      let profile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && profile.data.commentRestrictionUntil != null && duration.value(request.time - timestamp.value(profile.data.commentRestrictionUntil)) < 0;
    }

    function isFriend(userId) {
      let friendshipId = request.auth.uid < userId 
        ? request.auth.uid + "_" + userId 
        : userId + "_" + request.auth.uid;
      return isSignedIn() && exists(/databases/$(database)/documents/friendships/$(friendshipId));
    }

    function isBlockedBy(userId) {
      let targetProfile = get(/databases/$(database)/documents/users/$(userId));
      return isSignedIn() && request.auth.uid in targetProfile.data.blockedUserIds;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || resource.data.isPublic == true || isFriend(userId) || isAdmin();
      allow list: if isSignedIn() && (request.query.limit <= 20 || isAdmin()); 
      
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /history/{historyId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if (isSignedIn() && !isBlockedBy(userId)) || isAdmin();
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && !isSuspended();
      allow update, delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.userIds && !isSuspended();
      allow delete: if isSignedIn() && request.auth.uid in resource.data.userIds;
    }

    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId && !isSuspended() && !isBlockedBy(request.resource.data.receiverId);
      allow update: if isSignedIn() && (request.auth.uid == resource.data.receiverId);
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && !isSuspended());
      allow delete: if isAdmin();

      match /episodes/{episodeId} {
        allow get, list: if true;
        allow create: if isAdmin();
        allow update, delete: if isAdmin();

        match /comments/{commentId} {
          allow get, list: if true;
          allow create: if isSignedIn() && !isSuspended() && !isCommentRestricted() && request.resource.data.userId == request.auth.uid;
          allow update: if (isSignedIn() && !isSuspended() && resource.data.userId == request.auth.uid) || isAdmin();
          allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
        }
      }
    }

    match /ratings/{ratingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && !isSuspended() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && !isSuspended() && resource.data.userId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /comment_votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn() && !isSuspended() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && !isSuspended() && resource.data.userId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /global_notifications/{notificationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
