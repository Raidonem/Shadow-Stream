
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and application-specific settings.",
      "properties": {
        "id": {
          "type": "string"
        },
        "externalAuthId": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        },
        "isPremium": {
          "type": "boolean"
        },
        "isPublic": {
          "type": "boolean"
        },
        "languagePreference": {
          "type": "string"
        },
        "themePreference": {
          "type": "string"
        },
        "lastUsernameChange": {
          "type": "string",
          "format": "date-time"
        },
        "watchlistAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "currentlyWatchingAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "favoriteAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "completedAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedUserIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "externalAuthId",
        "username",
        "displayName",
        "email",
        "role"
      ]
    },
    "Report": {
      "title": "Report",
      "type": "object",
      "description": "Represents a user-submitted issue report.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["episode_server"] },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "animeId": { "type": "string" },
        "episodeId": { "type": "string" },
        "animeTitleEn": { "type": "string" },
        "episodeNumber": { "type": "number" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profiles, preferences, and watchlist."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Stores issue reports for moderation."
    },
    "/anime/{animeId}": {
      "schema": "Anime",
      "description": "Stores public information about anime series."
    }
  }
}
