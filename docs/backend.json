
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "suspendedUntil": { "type": "string", "format": "date-time" },
        "restrictedUntil": { "type": "string", "format": "date-time" }
      }
    },
    "Report": {
      "title": "Report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["episode_server", "comment"] },
        "userId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "commentId": { "type": "string" },
        "reportedUserId": { "type": "string" }
      }
    },
    "ModerationLog": {
      "title": "ModerationLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "action": { "type": "string", "enum": ["warning", "restriction", "suspension"] },
        "duration": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/reports/{reportId}": { "schema": "Report", "description": "Issue reports" },
    "/users/{userId}/moderation_logs/{logId}": { "schema": "ModerationLog", "description": "Logs of admin actions on a user" }
  }
}
