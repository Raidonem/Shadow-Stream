
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and application-specific settings.",
      "properties": {
        "id": {
          "type": "string"
        },
        "externalAuthId": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        },
        "isPremium": {
          "type": "boolean"
        },
        "isPublic": {
          "type": "boolean"
        },
        "languagePreference": {
          "type": "string"
        },
        "themePreference": {
          "type": "string"
        },
        "lastUsernameChange": {
          "type": "string",
          "format": "date-time"
        },
        "watchlistAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "currentlyWatchingAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "favoriteAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "completedAnimeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedUserIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "externalAuthId",
        "username",
        "displayName",
        "email",
        "role"
      ]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profiles, preferences, and watchlist."
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "WatchHistory",
      "description": "Stores user's watched episodes history."
    },
    "/users/{userId}/notifications/{notifId}": {
      "schema": "UserNotification",
      "description": "Personal notifications."
    },
    "/friendships/{friendshipId}": {
      "schema": "Friendship",
      "description": "Stores mutual friendship connections."
    },
    "/friend_requests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Stores pending friend requests."
    },
    "/admins/{adminId}": {
      "schema": "object",
      "description": "Dedicated collection for administrative role assignment."
    },
    "/anime/{animeId}": {
      "schema": "Anime",
      "description": "Stores public information about anime series."
    }
  }
}
